# ============================================================
# File: .env.example
# Module: Docker Local Environment
#
# Responsibility:
# Provides an example of the environment variables required by docker-compose.
#
# Interaction:
# Copy this file to .env and replace placeholder values before running Docker.
#
# Security:
# Do not commit the real .env file.
# ============================================================

DB_NAME=qa_store_db
DB_USERNAME=qa_store_user
DB_PASSWORD=change_me_database_password
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_HOST_PORT=3307

JWT_SECRET=REPLACE_WITH_BASE64_32_BYTE_SECRET
JWT_EXPIRATION_MS=3600000